# wardrowbe-mcp configuration (environment variables).
# Every CLI flag has a matching MCP_* (or WARDROWBE_URL) env var; flags win.
# Copy to .env and fill in. Do NOT commit a real .env.

# --- Required for http transport ---
# Incoming bearer key clients must present (Authorization: Bearer ...).
MCP_API_KEY=

# Backend base URL (no /api/v1).
WARDROWBE_URL=http://backend.wardrowbe.svc.cluster.local:8000

# --- Transport / bind ---
# (Inline comments are avoided: `docker run --env-file` and systemd
# EnvironmentFile would include them in the value.)
# http (Streamable HTTP) or stdio
MCP_TRANSPORT=http
MCP_BIND_HOST=0.0.0.0
MCP_BIND_PORT=8080

# --- Auth ---
# dev or oidc
MCP_AUTH_MODE=dev
# Dev identity sent to /auth/sync (auth=dev). Must match the web user's external_id.
MCP_EXTERNAL_ID=
MCP_EXTERNAL_EMAIL=

# OIDC (auth=oidc). Keep the secret/refresh token out of shell history and args.
MCP_OIDC_ISSUER_URL=
MCP_OIDC_CLIENT_ID=
MCP_OIDC_CLIENT_SECRET=
# Provide exactly one token source. MCP_OIDC_REFRESH_TOKEN is the durable path
# (a fresh id_token is minted per sync). MCP_OIDC_ID_TOKEN is a static fallback
# for issuers that do not issue refresh tokens; it expires and is not renewed.
MCP_OIDC_REFRESH_TOKEN=
MCP_OIDC_ID_TOKEN=
# Path (not a secret) to persist + reload the rotated refresh token across
# restarts. Required for IdPs that rotate refresh tokens single-use (e.g.
# Cloudflare Access); point it at a persistent volume.
MCP_OIDC_REFRESH_TOKEN_FILE=
# Optional: token endpoint override (skips discovery); must be https.
MCP_OIDC_TOKEN_ENDPOINT=

# --- Limits / behavior ---
# Inbound /mcp body cap (MiB)
MCP_MAX_BODY_MB=40
# debug, info, warn, or error
MCP_LOG_LEVEL=INFO
# Max returned image dimension
MCP_IMAGE_MAX_DIM=768
# thumb, medium, or full
MCP_IMAGE_VARIANT=medium

# Emits RFC 9728 resource_metadata on 401 (Cloudflare Access MCP portal).
MCP_PORTAL_RESOURCE_URL=
