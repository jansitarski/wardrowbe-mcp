# wardrowbe-mcp configuration (environment variables).
# Every CLI flag has a matching MCP_* (or WARDROWBE_URL) env var; flags win.
# Copy to .env and fill in. Do NOT commit a real .env.

# --- Required for http transport ---
# Incoming bearer key clients must present (Authorization: Bearer ...).
MCP_API_KEY=

# Backend base URL (no /api/v1).
WARDROWBE_URL=http://backend.wardrowbe.svc.cluster.local:8000

# --- Transport / bind ---
MCP_TRANSPORT=http        # http (Streamable HTTP) or stdio
MCP_BIND_HOST=0.0.0.0
MCP_BIND_PORT=8080

# --- Auth ---
MCP_AUTH_MODE=dev         # dev or oidc
# Dev identity sent to /auth/sync (auth=dev). Must match the web user's external_id.
MCP_EXTERNAL_ID=
MCP_EXTERNAL_EMAIL=

# OIDC (auth=oidc). Keep the secret/refresh token out of shell history and args.
MCP_OIDC_ISSUER_URL=
MCP_OIDC_CLIENT_ID=
MCP_OIDC_CLIENT_SECRET=
MCP_OIDC_REFRESH_TOKEN=

# --- Limits / behavior ---
MCP_MAX_CONCURRENT=16     # in-flight /mcp request cap
MCP_MAX_BODY_MB=40        # inbound /mcp body cap (MiB)
MCP_LOG_LEVEL=INFO        # debug, info, warn, or error
MCP_IMAGE_MAX_DIM=768     # max returned image dimension
MCP_IMAGE_VARIANT=medium  # thumb, medium, or full

# Emits RFC 9728 resource_metadata on 401 (Cloudflare Access MCP portal).
MCP_PORTAL_RESOURCE_URL=
